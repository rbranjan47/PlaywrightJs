{
  "name": "Playwright JS_TS",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "npx playwright test",
    "test:chromium": "playwright test --project=Chromium",
    "test:firefox": "playwright test --project=Firefox",
    "test:webkit": "playwright test --project=WebKit",
    "test:report": "npx playwright test && npx playwright show-report",
    "test:openreport": "npx playwright show-report",
    "test:ui": "playwright test --ui",
    "tests:api": "playwright test --config=api.config.ts --project=Chromium",
    "build": "tsc"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^20.19.42",
    "allure-commandline": "^2.42.0",
    "allure-playwright": "^3.9.0",
    "dotenv": "^17.4.0",
    "ts-node": "^10.9.2"
  },
  "dependencies": {
    "@cucumber/cucumber": "^13.0.0",
    "exceljs": "^4.4.0",
    "playwright": "^1.41.2"
  }
}
